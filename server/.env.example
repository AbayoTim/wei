# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email Configuration (SMTP)
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# Production: use a transactional provider (SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=info@wei.or.tz

# Admin notification email
ADMIN_EMAIL=admin@wei.or.tz

# Frontend URL — used for CORS, email confirmation links, and admin links
# Comma-separate multiple origins in production, e.g. https://wei.or.tz,https://www.wei.or.tz
FRONTEND_URL=http://localhost:3000

# Admin Initial Setup
ADMIN_PASSWORD=ChangeThisPassword123!
