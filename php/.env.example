# Application
APP_ENV=development

# JWT Secret — generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email (SMTP)
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=info@wei.or.tz

# Admin notification email
ADMIN_EMAIL=admin@wei.or.tz

# Frontend URL — used for CORS, email links, and redirects
# Comma-separate multiple origins: https://wei.or.tz,https://www.wei.or.tz
FRONTEND_URL=http://localhost:8000

# Admin initial credentials (used only when seeding — change after first login)
ADMIN_PASSWORD=ChangeThisPassword123!
